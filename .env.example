AZURE_DEVOPS_PAT=your_pat_here
# Optional defaults for repo/PR context.
# If omitted, script will auto-detect from current repo origin URL when possible.
AZURE_DEVOPS_ORG=your_org
AZURE_DEVOPS_PROJECT=your_repo_project
AZURE_DEVOPS_REPO=your_repo

# Optional when work items are in a different project.
AZURE_DEVOPS_WORKITEM_PROJECT=your_work_item_project
